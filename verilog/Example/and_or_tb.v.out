#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5ad6261b9380 .scope module, "and_or_tb" "and_or_tb" 2 5;
 .timescale -9 -12;
v0x5ad6261df5a0_0 .var "A", 0 0;
v0x5ad6261df660_0 .net "AND_OUT", 0 0, L_0x5ad6261df900;  1 drivers
v0x5ad6261df730_0 .var "B", 0 0;
v0x5ad6261df830_0 .net "OR_OUT", 0 0, L_0x5ad6261dfa60;  1 drivers
S_0x5ad6261cc7f0 .scope module, "uut" "and_or_top" 2 14, 3 1 0, S_0x5ad6261b9380;
 .timescale -9 -12;
    .port_info 0 /INPUT 1 "A";
    .port_info 1 /INPUT 1 "B";
    .port_info 2 /OUTPUT 1 "AND_OUT";
    .port_info 3 /OUTPUT 1 "OR_OUT";
L_0x5ad6261df900 .functor AND 1, v0x5ad6261df5a0_0, v0x5ad6261df730_0, C4<1>, C4<1>;
L_0x5ad6261dfa60 .functor OR 1, v0x5ad6261df5a0_0, v0x5ad6261df730_0, C4<0>, C4<0>;
v0x5ad6261cca40_0 .net "A", 0 0, v0x5ad6261df5a0_0;  1 drivers
v0x5ad6261df2a0_0 .net "AND_OUT", 0 0, L_0x5ad6261df900;  alias, 1 drivers
v0x5ad6261df360_0 .net "B", 0 0, v0x5ad6261df730_0;  1 drivers
v0x5ad6261df430_0 .net "OR_OUT", 0 0, L_0x5ad6261dfa60;  alias, 1 drivers
    .scope S_0x5ad6261b9380;
T_0 ;
    %vpi_call 2 24 "$dumpfile", "waveform.vcd" {0 0 0};
    %vpi_call 2 25 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x5ad6261b9380 {0 0 0};
    %vpi_call 2 27 "$display", "A B | AND OR" {0 0 0};
    %vpi_call 2 28 "$monitor", "%b %b |  %b   %b", v0x5ad6261df5a0_0, v0x5ad6261df730_0, v0x5ad6261df660_0, v0x5ad6261df830_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5ad6261df5a0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5ad6261df730_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5ad6261df5a0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5ad6261df730_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5ad6261df5a0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5ad6261df730_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5ad6261df5a0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5ad6261df730_0, 0, 1;
    %delay 10000, 0;
    %delay 10000, 0;
    %vpi_call 2 35 "$finish" {0 0 0};
    %end;
    .thread T_0;
# The file index is used to find the file name in the following table.
:file_names 4;
